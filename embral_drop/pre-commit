#!/usr/bin/env bash
# Embral File Protection System
# Install path: /var/lib/phoenix-ai/workspace/embral/.git/hooks/pre-commit
# Also install globally: git config --global core.hooksPath ~/.git-hooks/
#
# WHAT THIS DOES:
# 1. Blocks commits with banned dependency patterns (SQLite, Ollama, etc.)
# 2. Blocks scatterbuild filenames (_fixed, _v2, *(1), etc.)
# 3. Blocks Tailscale IPs
# 4. Blocks scripts dumped in docs/ folder
# 5. Warns about files not registered in manifest.yaml

set -e

ERRORS=0
WARNINGS=0
REPO_ROOT="$(git rev-parse --show-toplevel)"
MANIFEST="$REPO_ROOT/manifest.yaml"

echo ""
echo "🔥 Embral pre-commit protection running..."
echo "─────────────────────────────────────────"

# ═══════════════════════════════════════════
# LAW 1: NO SECRETS
# ═══════════════════════════════════════════
STAGED="$(git diff --cached --name-only 2>/dev/null)"

for file in $STAGED; do
    if [ -f "$file" ]; then
        # Tailscale IPs
        if grep -qE "100\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}" "$file" 2>/dev/null; then
            echo "❌ LAW 1: Tailscale IP found in $file"
            ERRORS=$((ERRORS + 1))
        fi
        # API token patterns
        if grep -qE "(sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{30,}|Bearer [a-zA-Z0-9]{20,})" "$file" 2>/dev/null; then
            echo "❌ LAW 1: Possible API token in $file"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done

# ═══════════════════════════════════════════
# LAW 2: NO IP VIOLATIONS
# ═══════════════════════════════════════════
IP_TERMS="toothless shenron dragonball dragon_ball spiderman nyan_cat doge_coin"
for term in $IP_TERMS; do
    MATCH="$(echo "$STAGED" | grep -i "$term" 2>/dev/null || true)"
    if [ -n "$MATCH" ]; then
        echo "❌ LAW 2: IP term '$term' in filename: $MATCH"
        ERRORS=$((ERRORS + 1))
    fi
done

# ═══════════════════════════════════════════
# LAW 3: NO BANNED DEPENDENCIES
# ═══════════════════════════════════════════
BANNED_PATTERNS="godot-sqlite sqlite3 sqlite_stub chromadb ollama victoria_ai amber_rag"
for file in $STAGED; do
    if [ -f "$file" ]; then
        for pattern in $BANNED_PATTERNS; do
            if grep -qi "$pattern" "$file" 2>/dev/null; then
                # Exclude this hook file and manifest banned: section itself
                if [[ "$file" != *"pre-commit"* ]] && [[ "$file" != "manifest.yaml" ]] && [[ "$file" != "AGENTS.md" ]]; then
                    echo "❌ LAW 3: Banned dependency '$pattern' found in $file"
                    ERRORS=$((ERRORS + 1))
                fi
            fi
        done
    fi
done

# ═══════════════════════════════════════════
# LAW 4: NO SCATTERBUILD FILENAMES
# ═══════════════════════════════════════════
SCATTER_PATTERNS="_fixed\. _clean\. _working\. _v2\. _v3\. _old\. _backup\. _temp\."
for pattern in $SCATTER_PATTERNS; do
    MATCH="$(echo "$STAGED" | grep -i "$pattern" 2>/dev/null || true)"
    if [ -n "$MATCH" ]; then
        echo "❌ LAW 4: Scatterbuild filename '$pattern': $MATCH"
        echo "   Edit the existing file instead of creating a variant."
        ERRORS=$((ERRORS + 1))
    fi
done

# Check for (1) pattern
PAREN_MATCH="$(echo "$STAGED" | grep -E " \(1\)\." 2>/dev/null || true)"
if [ -n "$PAREN_MATCH" ]; then
    echo "❌ LAW 4: Duplicate file with (1) suffix: $PAREN_MATCH"
    ERRORS=$((ERRORS + 1))
fi

# ═══════════════════════════════════════════
# SCRIPTS IN DOCS
# ═══════════════════════════════════════════
SCRIPTS_IN_DOCS="$(echo "$STAGED" | grep "^docs/.*\.gd$" 2>/dev/null || true)"
if [ -n "$SCRIPTS_IN_DOCS" ]; then
    echo "❌ STRUCTURE: GDScript in docs/: $SCRIPTS_IN_DOCS"
    echo "   Scripts belong in scripts/ — never in docs/"
    ERRORS=$((ERRORS + 1))
fi

# ═══════════════════════════════════════════
# NEVER-COMMIT DIRS
# ═══════════════════════════════════════════
FORBIDDEN="node_modules/ .godot/imported/ legacy_quarantine/"
for path in $FORBIDDEN; do
    MATCH="$(echo "$STAGED" | grep "$path" 2>/dev/null || true)"
    if [ -n "$MATCH" ]; then
        echo "❌ FORBIDDEN: '$path' must never be committed"
        ERRORS=$((ERRORS + 1))
    fi
done

# ═══════════════════════════════════════════
# WARNING: FILES NOT IN MANIFEST
# ═══════════════════════════════════════════
if [ -f "$MANIFEST" ]; then
    for file in $STAGED; do
        # Only check .gd, .tscn, .json in data/ and scripts/
        if [[ "$file" =~ ^(scripts|data|scenes)/ ]]; then
            BASENAME="$(basename "$file")"
            if ! grep -q "$BASENAME" "$MANIFEST" 2>/dev/null; then
                echo "⚠️  MANIFEST: $file not found in manifest.yaml"
                echo "   Register it before committing (or this is a warning only)."
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    done
fi

# ═══════════════════════════════════════════
# UID FILES WARNING
# ═══════════════════════════════════════════
UID_FILES="$(echo "$STAGED" | grep "\.uid$" 2>/dev/null || true)"
if [ -n "$UID_FILES" ]; then
    echo "⚠️  UID FILES: These are auto-generated by Godot:"
    echo "$UID_FILES" | head -5 | sed 's/^/   /'
    echo "   Add *.uid to .gitignore if not already present."
    WARNINGS=$((WARNINGS + 1))
fi

# ═══════════════════════════════════════════
# RESULT
# ═══════════════════════════════════════════
echo "─────────────────────────────────────────"

if [ "$ERRORS" -gt 0 ]; then
    echo "❌ BLOCKED: $ERRORS violation(s) found. Fix before committing."
    echo "   See AGENTS.md for the full rule set."
    echo ""
    exit 1
elif [ "$WARNINGS" -gt 0 ]; then
    echo "⚠️  $WARNINGS warning(s). Commit allowed but review recommended."
    echo "✅ Pre-commit checks passed with warnings."
    echo ""
    exit 0
else
    echo "✅ All checks passed. Committing..."
    echo ""
    exit 0
fi
