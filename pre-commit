#!/bin/bash
# Embral pre-commit hook
# Enforces AGENTS.md laws before any commit lands
# Install: cp this file to .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

ERRORS=0

echo "🔥 Embral pre-commit check running..."

# ═══════════════════════════════════════════
# LAW 1 — NO SECRETS / REAL IPs
# ═══════════════════════════════════════════

# Check for Tailscale IP patterns (100.x.x.x)
if git diff --cached --name-only | xargs grep -l "100\.\([0-9]\{1,3\}\)\.\([0-9]\{1,3\}\)\.\([0-9]\{1,3\}\)" 2>/dev/null; then
    echo "❌ LAW 1 VIOLATION: Tailscale IP (100.x.x.x) detected in staged files."
    echo "   Remove all real IPs. Use environment variables or secret-tool."
    ERRORS=$((ERRORS + 1))
fi

# Check for common secret patterns
STAGED_FILES=$(git diff --cached --name-only)
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Check for obvious token patterns
        if grep -qE "(sk-[a-zA-Z0-9]{32,}|ghp_[a-zA-Z0-9]{36,}|Bearer [a-zA-Z0-9]{20,})" "$file" 2>/dev/null; then
            echo "❌ LAW 1 VIOLATION: Possible API token detected in $file"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done

# ═══════════════════════════════════════════
# LAW 2 — NO IP VIOLATIONS
# ═══════════════════════════════════════════

# Check for known IP character names
IP_TERMS=("toothless" "shenron" "dragonball" "dragon_ball" "spiderman" "nyan_cat" "doge_coin")
for term in "${IP_TERMS[@]}"; do
    if git diff --cached --name-only | grep -qi "$term" 2>/dev/null; then
        echo "❌ LAW 2 VIOLATION: Possible IP term '$term' in filename."
        ERRORS=$((ERRORS + 1))
    fi
done

# ═══════════════════════════════════════════
# LAW 4 — NO SCATTERBUILD FILENAMES
# ═══════════════════════════════════════════

SCATTERBUILD_PATTERNS=("_fixed\." "_clean\." "_working\." "_v2\." " (1)\." "_backup\." "_old\." "_temp\.")
for pattern in "${SCATTERBUILD_PATTERNS[@]}"; do
    MATCHES=$(git diff --cached --name-only | grep -i "$pattern" 2>/dev/null || true)
    if [ -n "$MATCHES" ]; then
        echo "❌ LAW 4 VIOLATION: Scatterbuild filename pattern '$pattern' detected:"
        echo "   $MATCHES"
        echo "   Edit the existing file instead of creating a variant."
        ERRORS=$((ERRORS + 1))
    fi
done

# ═══════════════════════════════════════════
# NEVER-COMMIT PATHS
# ═══════════════════════════════════════════

FORBIDDEN_PATHS=("node_modules/" ".godot/imported/" "legacy_quarantine/" "user://")
for path in "${FORBIDDEN_PATHS[@]}"; do
    if git diff --cached --name-only | grep -q "$path" 2>/dev/null; then
        echo "❌ FORBIDDEN PATH: '$path' must never be committed."
        ERRORS=$((ERRORS + 1))
    fi
done

# ═══════════════════════════════════════════
# SCRIPTS IN WRONG LOCATIONS
# ═══════════════════════════════════════════

# Scripts should not be in docs/ directory
SCRIPTS_IN_DOCS=$(git diff --cached --name-only | grep "^docs/.*\.gd$" 2>/dev/null || true)
if [ -n "$SCRIPTS_IN_DOCS" ]; then
    echo "❌ STRUCTURE VIOLATION: GDScript files found in docs/:"
    echo "   $SCRIPTS_IN_DOCS"
    echo "   Scripts belong in scripts/ — not docs/"
    ERRORS=$((ERRORS + 1))
fi

# ═══════════════════════════════════════════
# RESULT
# ═══════════════════════════════════════════

if [ $ERRORS -gt 0 ]; then
    echo ""
    echo "❌ Pre-commit failed with $ERRORS violation(s)."
    echo "   Fix all violations before committing."
    echo "   See AGENTS.md for the full rule set."
    exit 1
else
    echo "✅ Pre-commit checks passed. Committing..."
    exit 0
fi
