theme_override_constants/separation = 15

[node name="TitleLabel" type="Label" parent="PinPanel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "Parent Access"
horizontal_alignment = 1

[node name="InstructionLabel" type="Label" parent="PinPanel/VBox"]
layout_mode = 2
