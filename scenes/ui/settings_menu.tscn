[connection signal="toggled" from="Control/Panel/VBox/HardwareSection/Grid/WiiCheck" to="." method="_on_wii_check_toggled"]
[connection signal="toggled" from="Control/Panel/VBox/HardwareSection/Grid/HACheck" to="." method="_on_ha_check_toggled"]
[connection signal="item_selected" from="Control/Panel/VBox/CheckinSection/FrequencyDropdown" to="." method="_on_frequency_dropdown_item_selected"]
[connection signal="pressed" from="Control/Panel/VBox/PINSection/SetPINButton" to="." method="_on_set_pin_button_pressed"]
[connection signal="pressed" from="Control/Panel/VBox/CloseButton" to="." method="_on_close_button_pressed"]
