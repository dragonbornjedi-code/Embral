[gd_scene load_steps=2 format=3 uid="uid://emotionalcheckin"]

[ext_resource type="Script" path="res://scripts/ui/emotional_checkin.gd" id="1_script"]

[node name="EmotionalCheckin" type="CanvasLayer"]
script = ExtResource("1_script")

[node name="Control" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="Panel" parent="Control"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -150.0
offset_right = 200.0
offset_bottom = 150.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Control/Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 20
alignment = 1

[node name="Label" type="Label" parent="Control/Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
text = "How are you feeling?"
horizontal_alignment = 1

[node name="Grid" type="GridContainer" parent="Control/Panel/VBox"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_constants/h_separation = 20
theme_override_constants/v_separation = 20
columns = 2

[node name="Happy" type="Button" parent="Control/Panel/VBox/Grid"]
custom_minimum_size = Vector2(120, 60)
layout_mode = 2
text = "😊 Happy"

[node name="Sad" type="Button" parent="Control/Panel/VBox/Grid"]
custom_minimum_size = Vector2(120, 60)
layout_mode = 2
text = "😢 Sad"

[node name="Angry" type="Button" parent="Control/Panel/VBox/Grid"]
custom_minimum_size = Vector2(120, 60)
layout_mode = 2
text = "😠 Angry"

[node name="Worried" type="Button" parent="Control/Panel/VBox/Grid"]
custom_minimum_size = Vector2(120, 60)
layout_mode = 2
text = "😨 Worried"

[node name="CloseButton" type="Button" parent="Control/Panel/VBox"]
layout_mode = 2
size_flags_horizontal = 4
text = "Not now"

[node name="CheckinTimer" type="Timer" parent="."]
autostart = true

[connection signal="pressed" from="Control/Panel/VBox/Grid/Happy" to="." method="_on_emotion_pressed" binds= ["happy"]]
[connection signal="pressed" from="Control/Panel/VBox/Grid/Sad" to="." method="_on_emotion_pressed" binds= ["sad"]]
[connection signal="pressed" from="Control/Panel/VBox/Grid/Angry" to="." method="_on_emotion_pressed" binds= ["angry"]]
[connection signal="pressed" from="Control/Panel/VBox/Grid/Worried" to="." method="_on_emotion_pressed" binds= ["worried"]]
[connection signal="pressed" from="Control/Panel/VBox/CloseButton" to="." method="_on_close_pressed"]
