; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Embral"
config/description="Open-source educational RPG for children ages 4-8"
config/version="0.1.0"
config/tags=PackedStringArray("educational", "rpg", "children", "godot4")
run/main_scene="res://scenes/boot.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/autoloads/event_bus.gd"
HardwareManager="*res://scripts/autoloads/hardware_manager.gd"
HABridge="*res://scripts/autoloads/ha_bridge.gd"
QuestManager="*res://scripts/autoloads/quest_manager.gd"
ConfigLoader="*res://scripts/autoloads/config_loader.gd"
SaveManager="*res://scripts/autoloads/save_manager.gd"
TransitionManager="*res://scripts/autoloads/transition_manager.gd"
DialogicStub="*res://scripts/autoloads/dialogic_stub.gd"
Dialogic="*uid://ds2q0uclmolvu"
ErrorLogger="*res://scripts/autoloads/error_logger.gd"
Telemetry="*res://scripts/autoloads/telemetry.gd"
WispRoster="*res://scripts/autoloads/wisp_roster.gd"
crystal_system="*res://scripts/dungeon/crystal_system.gd"
GlobalVars="*uid://carap1rlfbkyy"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"

[dialogic]

directories/dch_directory={}
directories/dtl_directory={}
layout/style_directory={}

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/godot_ai/plugin.cfg", "res://addons/godot_mcp/plugin.cfg", "res://addons/logic_bricks/plugin.cfg", "res://addons/rider-plugin/plugin.cfg", "res://addons/terrain_3d/plugin.cfg")

