; Engine configuration file.
; Embral — Educational RPG for children ages 4-8
; https://github.com/dragonbornjedi-code/Embral

config_version=5

[application]

config/name="Embral"
config/description="Open-source educational RPG for children ages 4-8"
config/version="0.1.0"
config/tags=PackedStringArray("educational", "rpg", "children", "godot4")
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/textures/icon.svg"

[autoload]

EventBus="*res://scripts/autoloads/event_bus.gd"
HardwareManager="*res://scripts/autoloads/hardware_manager.gd"
HABridge="*res://scripts/autoloads/ha_bridge.gd"
QuestManager="*res://scripts/autoloads/quest_manager.gd"
ConfigLoader="*res://scripts/autoloads/config_loader.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/stretch/mode="canvas_items"

